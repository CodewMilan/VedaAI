PORT=4000
NODE_ENV=development

# MongoDB — local Docker or Atlas connection string
MONGODB_URI=mongodb://localhost:27017/vedaai

# Redis (used for both cache & BullMQ)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000

# AI provider — works with OpenAI or any OpenAI-compatible API (e.g. OpenRouter)
# Leave OPENAI_API_KEY empty to use the built-in mock generator instead
OPENAI_API_KEY=
# Override base URL for OpenRouter: https://openrouter.ai/api/v1
# Leave empty to use the default OpenAI endpoint
OPENAI_BASE_URL=
# For OpenRouter use the full model path, e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku
OPENAI_MODEL=openai/gpt-4o-mini

# Job tuning
GENERATION_CONCURRENCY=2
